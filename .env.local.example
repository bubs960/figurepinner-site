# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to git

# Clerk Auth (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# FigurePinner API
NEXT_PUBLIC_API_BASE=https://figurepinner-api.bubs960.workers.dev
# Client-tier token (web_fp_2026) — not yet issued, leave blank for Phase 1
NEXT_PUBLIC_FP_CLIENT_TOKEN=

# eBay Partner Network affiliate tag
NEXT_PUBLIC_EBAY_CAMPAIGN_ID=5339147406
